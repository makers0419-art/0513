{
  "version": "2.2",
  "rules": {
    "primary_keyword_first": true,
    "must_include_numbers_or_effect": true,
    "avoid_sensationalism": true,
    "recommended_length_chars_range": [
      22,
      36
    ],
    "hard_max_length": 45,
    "ban_words": [
      "무료",
      "무조건",
      "100%",
      "확실",
      "보장"
    ],
    "ban_clickbait_patterns": [
      "충격",
      "역대급",
      "무조건 이득",
      "몰랐다면 손해",
      "대박",
      "실화",
      "단독"
    ],
    "mobile_truncation_guard": {
      "avoid_tail_cliff": true,
      "avoid_parentheses_overuse": true
    },
    "require_update_stamp_when_policy_changes": true,
    "prefer_date_token": "{ASOF_DATE}",
    "formats": [
      "{KEYWORD} {NUMBER}가지로 정리 ({ASOF_DATE} 기준)",
      "{ASOF_DATE} 기준 {KEYWORD} 정리: 가산세/감면/준비서류",
      "{TARGET} {KEYWORD} 체크: 지금 해야 할 3가지 ({ASOF_DATE})"
    ]
  }
}
