{
  "version": "2.3",
  "tone": {
    "style": "실무형 권위 회계사",
    "ending": "습니다",
    "avoid_ai_phrases": true,
    "avoid_exaggeration": true,
    "avoid_slang": true,
    "prefer_short_sentences": true
  },
  "naver_blog": {
    "mobile_first": true,
    "toc": {
      "enabled": true,
      "position": "after_intro",
      "max_items": 6
    },
    "mid_summary": {
      "enabled": true,
      "position_mode": "rotating",
      "positions": [
        "after_section_2",
        "after_section_3"
      ]
    },
    "section_order_rotation": {
      "enabled": true,
      "variants": [
        "A",
        "B",
        "C"
      ]
    },
    "dwell_time_design": {
      "require_one_readability_device_every_words": 260,
      "allowed_devices": [
        "mini_check",
        "mini_summary",
        "quote",
        "simple_table_text"
      ]
    },
    "engagement_nudges": {
      "include_neighbor_hint_line": true,
      "include_next_post_teaser": true,
      "avoid_bot_like_requests": true
    }
  },
  "intent_engine": {
    "intents": [
      "정보형",
      "위기형",
      "비교형",
      "전환형",
      "체크형"
    ],
    "heuristics": {
      "위기형": [
        "마감",
        "기한",
        "가산세",
        "추징",
        "조사",
        "통지",
        "기한후"
      ],
      "비교형": [
        "차이",
        "비교",
        "vs",
        "어느",
        "유리",
        "장단점"
      ],
      "전환형": [
        "대행",
        "상담",
        "의뢰",
        "수수료",
        "문의"
      ],
      "체크형": [
        "체크리스트",
        "준비",
        "점검",
        "확인",
        "방법"
      ],
      "정보형": [
        "정리",
        "기준",
        "서류",
        "절차",
        "신고"
      ]
    },
    "structure_overrides": {
      "위기형": {
        "require_deadline_box": true,
        "faq_min": 6,
        "cta_strength": "medium"
      },
      "비교형": {
        "require_comparison_table": true,
        "cta_strength": "soft"
      },
      "전환형": {
        "require_case_study": true,
        "cta_strength": "strong_but_polite"
      },
      "체크형": {
        "require_checklist": true,
        "cta_strength": "soft"
      }
    }
  },
  "anti_ai": {
    "sentence_length_variation": {
      "enabled": true,
      "allow_very_short_paragraph_ratio": 0.15,
      "allow_long_paragraph_ratio": 0.15
    },
    "connector_variation": {
      "enabled": true,
      "avoid_repeating_starters": true
    },
    "opening_rotation": {
      "enabled": true,
      "patterns": [
        "공감형",
        "문제-해결약속형",
        "짧은사례형",
        "질문형"
      ]
    },
    "cta_rotation": {
      "enabled": true,
      "cta_variant_ids": [
        "CTA_A_PHONE_FIRST",
        "CTA_B_KAKAO_FIRST",
        "CTA_C_MINIMAL"
      ]
    },
    "caption_rotation": {
      "enabled": true,
      "choose_from_asset_templates": true
    }
  },
  "seo": {
    "first_120_chars_include_primary_keyword": true,
    "use_longtail_in_h2": true,
    "no_keyword_stuffing": true,
    "include_tables": true,
    "include_checklist": true,
    "include_faq": true,
    "min_characters": 1600,
    "recommended_characters_range": [
      1600,
      2600
    ],
    "paragraph_guardrails": {
      "recommended_chars_per_paragraph": [
        90,
        220
      ],
      "max_sentences_per_paragraph": 4,
      "newline_rule": "sentence_end_then_new_paragraph",
      "avoid_mid_sentence_newline": true
    },
    "image_text_alternation": {
      "enabled": true,
      "rule": "text-image-text-image",
      "min_images": 4,
      "require_caption": true,
      "caption_include_keyword": "soft"
    },
    "images": {
      "allowed_sources": [
        "image_assets"
      ],
      "allowed_url_prefixes": [
        "https://cdn.jsdelivr.net/gh/makers0419-art/0513@main/"
      ],
      "deny_other_urls": true
    },
    "keyword_distribution": {
      "primary_keyword_min_occurrences": 4,
      "primary_keyword_recommended_occurrences": [
        5,
        9
      ],
      "primary_keyword_must_appear_in": [
        "intro_first_120_chars",
        "one_h2_heading_or_nearby",
        "summary_or_cta"
      ],
      "secondary_keywords_min_unique": 4,
      "related_terms_min_unique": 8,
      "section_spread": "avoid_clumping",
      "ban_keyword_list_style": true
    },
    "links_policy": {
      "external_authoritative_links": {
        "min": 1,
        "max": 2,
        "preferred_domains_hint": [
          "hometax.go.kr",
          "nts.go.kr",
          "law.go.kr",
          "korea.kr",
          "moef.go.kr"
        ],
        "rule": "공식기관/법령/공신력 자료 우선"
      },
      "internal_links": {
        "min": 5,
        "max": 7,
        "rule": "토픽 클러스터(관련 글) 연결"
      }
    },
    "trust_signals": {
      "require_real_experience_section": true,
      "require_numeric_example": true,
      "require_sources_section": true,
      "require_scope_disclaimer": true
    },
    "duplication_control": {
      "require_unique_angle_per_post": true,
      "require_unique_example_numbers": true,
      "rotate_section_order_within_limits": true
    },
    "human_qc_checklist": {
      "spellcheck_required": true,
      "fact_check_required": true,
      "before_publish": [
        "맞춤법 검사",
        "금지표현/과장표현 확인",
        "외부출처 링크 정상작동 확인",
        "내부링크 1개 이상 확인"
      ]
    }
  },
  "conversion": {
    "cta_style": "정중하지만 구체적",
    "require_soft_cta": true,
    "require_scope_disclaimer": true,
    "require_fixed_footer_cta": false,
    "cta_links": {
      "phone_tel": "tel:0269532587",
      "kakao_chat": "http://pf.kakao.com/_UHxnxan/chat"
    }
  },
  "tags": {
    "position": "very_bottom",
    "min_total_chars": 80,
    "target_total_chars_range": [
      80,
      140
    ],
    "max_tags": 12,
    "avoid_duplicates": true,
    "required_tags": [
      "#세영세무회계",
      "#마곡회계사",
      "#마곡세무사",
      "#강서구세무사",
      "#은평구세무사"
    ],
    "required_tags_policy": "must_include_all"
  }
}
